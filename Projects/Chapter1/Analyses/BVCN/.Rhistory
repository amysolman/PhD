rc = (rc-.5)*2
results[null.two,null.one] = round(rc,digits=2); ##store the metric in the results matrix
print(c(null.one,null.two,date()));
}; ## end null.two loop
}; ## end null.one loop
results<-as.dist(results)
return(results)
}
