?nlsLM
#First define the power law function
powMod <- function(x, c, z) {
return(c * x^z)
}
#Now use the function to perform non-linear least squares fitting
PowFit_Canada <- nlsLM(ASVs ~ powMod(Area_cm2,c,z), data = data[data$Glacier == "Canada", ], start = list(c = .1, z = .1))
#we can look at the model summary
summary(PowFit_Canada)
PowFit_Taylor <- nlsLM(ASVs ~ powMod(Area_cm2,c,z), data = data[data$Glacier == "Taylor", ], start = list(c = .1, z = .1))
#Let's get ready to plot! Generate areas to use
Areas <- seq(min(data$Area_cm2),max(data$Area_cm2),len=200)
#Now we use the coefficients from our fit to generate predictive points to plot with our data
Predic2PlotPow_Canada <- powMod(Areas,coef(PowFit_Canada)["c"],coef(PowFit_Canada)["z"])
Predic2PlotPow_Taylor <- powMod(Areas,coef(PowFit_Taylor)["c"],coef(PowFit_Taylor)["z"])
df1 <- data.frame(Areas, Predic2PlotPow_Canada)
df1$model <- "Power Law"
names(df1) <- c("Area_cm2", "ASVs", "Model")
View(df1)
ggplot(data, aes(x = Area_cm2, y = ASVs, color=Glacier)) +
geom_point(size = 3) +
geom_line(data = df1, aes(x = Area_cm2, y = ASVs, col = Model), size = 1) +
theme(aspect.ratio=1)#+ # make the plot square
df1 <- data.frame(Areas, Predic2PlotPow_Canada)
names(df1) <- c("Area_cm2", "ASVs")
df2 <- data.frame(Areas, Predic2PlotPow_Taylor)
names(df2) <- c("Area_cm2", "ASVs")
ggplot(data, aes(x = Area_cm2, y = ASVs, color=Glacier)) +
geom_point(size = 3) +
geom_line(data = df1, aes(x = Area_cm2, y = ASVs), size = 1) +
geom_line(data = df2, aes(x = Area_cm2, y = ASVs), size = 1) +
theme(aspect.ratio=1)#+ # make the plot square
View(data)
ggplot(data, aes(x = Area_cm2, y = ASVs, color=Glacier)) +
geom_point(size = 3) +
geom_line(data = df1, aes(x = Area_cm2, y = ASVs), size = 1) +
#geom_line(data = df2, aes(x = Area_cm2, y = ASVs), size = 1) +
theme(aspect.ratio=1)#+ # make the plot square
ggplot(data, aes(x=Area_cm2, y=ASVs, color=Glacier))+
geom_point()+
xlab("Area (cm2)")+
ylab("ASVs")
ggplot(data, aes(x=Area_cm2, y=ASVs, color=Glacier))+
geom_point()+
geom_line(data = df1, aes(x = Area_cm2, y = ASVs), size = 1) +
xlab("Area (cm2)")+
ylab("ASVs")
df1 <- data.frame(Areas, Predic2PlotPow_Canada, c("Glacier"*200))
df1 <- data.frame(Areas, Predic2PlotPow_Canada, "Canada")
View(df1)
