asv_fasta <- read.fasta(file="export/rep-seqs.fasta/dna-sequences.fasta")
sample_info_tab <- read_csv(file="export/SraRunTable-wrangle.tsv")
#delete unneccessary row and column
sample_info_tab <- sample_info_tab[-c(1),]
sample_info_tab <- sample_info_tab[,-c(1)]
sample_info_tab <- sample_info_tab[!grepl("18S", sample_info_tab$Library.Name),] #only include 16S samples
sample_info_tab <- sample_info_tab[-c(42:80),] #remove reverse reads so we only have one entry per sample
# Make a logical vector that states which entries in the count_table are 'TRUE' for blanks/controls and 'FALSE' for genuine samples
vector_for_decontam <- startsWith(sample_info_tab$Library.Name, "NT")
# The command, isContaminant, expects a matrix with rows as samples and ASVs as columns. So first we need to convert our table from a tibble to a numeric (dataframe)
count_table_df <- as.data.frame(count_table)
# And run isContaminant, while transforming the matric with t()
contam_df <- isContaminant(t(count_table_df), neg=vector_for_decontam)
# Take a look at the results
table(contam_df$contaminant) # how many ASVs were identified as contaminants? None. Why?
# Make a vector holding the identified contaminant IDs
contam_asvs <- row.names(contam_df[contam_df$contaminant == TRUE, ])
# Check the taxonomy of these contaminants
taxonomy[taxonomy$`Feature ID` %in% contam_asvs] #Why don't I have any contaminants?!?
#Make a new fasta file without the contaminant ASVs
asv_fasta_no_contam <- asv_fasta
asv_fasta_no_contam[contam_asvs] <- NULL
# Make new count table
# set up logical vector for rows which are contamination
vector_for_contam_count_table <- rownames(count_table) %in% contam_asvs
# remove contaminating asvs
count_table_no_contam <- count_table[!vector_for_contam_count_table,]
# and remove blank samples
#what is the index of "TRUE" values in the vector_for_decontam
true_index <- NULL
for (i in 1:length(vector_for_decontam)){
if (vector_for_decontam[[i]] == "TRUE"){
true_index <- c(true_index, i)
}
}
count_table_no_contam <- count_table_no_contam[,-c(true_index)]  #remove those samples
#remove blanks FROM METADATA TABLW
x <- startsWith(sample_info_tab$Library.Name, "NT")
true_index <- NULL
for (i in 1:length(x)){
if (x[[i]] == "TRUE"){
true_index <- c(true_index, i)
}
}
sample_info_tab <- sample_info_tab[-c(true_index),]  #remove those samples
#add a column with glacier name
Glacier <- NULL
for (i in 1:nrow(sample_info_tab)){
if (startsWith(sample_info_tab$Sample.Name[[i]], "C")){
Glacier <- c(Glacier, "Canada")
} else {
Glacier <- c(Glacier, "Taylor")
}
}
sample_info_tab <- cbind(sample_info_tab, Glacier)
write_tsv(sample_info_tab, "results/cleaned_files/SraRunTable-mod.tsv")
# Make new taxonomy table
# set up a logical vector for rows which are contamination
vector_for_contam_taxonomy <- taxonomy$`Feature ID` %in% contam_asvs
#remove contaminating ASVs
taxonomy_no_contam <- taxonomy[!vector_for_contam_taxonomy,]
# Make a new tree file
# This is a phyloseq object so we can use a phyloseq command called prune_taxa
tree_no_contam <- prune_taxa(count_table_no_contam$`#OTU ID`, tree)
# Use rarecurve from the vegan package. Rarecurve expects teh datasetas a dataframe so we need to use as.data.frame again:
count_table_no_contam_df <- as.data.frame(count_table_no_contam)
#Plot the rarefaction curves, color-coding by the colors listed in sample_info_tab, which indicate sample type, and tranforming using t()
rarecurve(t(count_table_no_contam_df), step=100, cex=0.5, col=palette(rainbow(nrow(sample_info_tab))), lwd=2, ylab="ASVs", label=T)
# And add a veritical line to the plot indicating the fewest # of sequences from any sample
abline(v=(min(rowSums(t(count_table_no_contam_df)))))
# First convert to phyloseq package
count_table_no_contam_phyloseq <- otu_table(count_table_no_contam, taxa_are_rows = TRUE)
# Then filter using filter taxa
count_table_no_contam_no_singletons_phyloseq <- prune_taxa(taxa_sums(count_table_no_contam_phyloseq) > 1, count_table_no_contam_phyloseq)
row.names(count_table_no_contam_no_singletons_phyloseq)
###PHYLOGENETIC TREE
# This is a phyloseq object so we can use a phyloseq command called prune_taxa
tree_clean_and_single <- prune_taxa(count_table_phyloseq$`#OTU ID`, tree)
rm(list=ls())
graphics.off()
library(tidyverse)
library(phyloseq)
library(readr)
library(seqinr)
library(decontam)
library(ape)
library(vegan)
count_table <- read_tsv(file="export/table/table.tsv", skip=1)
taxonomy <- read_tsv(file="export/taxonomy/taxonomy.tsv")
tree <- read_tree("export/exported-tree/tree.nwk")
fasta <- read.fasta(file="export/rep-seqs.fasta/dna-sequences.fasta")
count_table <- column_to_rownames(count_table, var = colnames(count_table)[1])
sample_info_tab <- read_csv(file="export/SraRunTable-wrangle.tsv")
#delete unneccessary row and column
sample_info_tab <- sample_info_tab[-c(1),]
sample_info_tab <- sample_info_tab[,-c(1)]
sample_info_tab <- sample_info_tab[!grepl("18S", sample_info_tab$Library.Name),] #only include 16S samples
sample_info_tab <- sample_info_tab[-c(42:80),] #remove reverse reads so we only have one entry per sample
#add a column with glacier name
Glacier <- NULL
for (i in 1:nrow(sample_info_tab)){
if (startsWith(sample_info_tab$Sample.Name[[i]], "C")){
Glacier <- c(Glacier, "Canada")
} else {
Glacier <- c(Glacier, "Taylor")
}
}
sample_info_tab <- cbind(sample_info_tab, Glacier)
#Keep only the information from the metadata table that will be useful in later analysis
sampledata = sample_data(data.frame(
Sample_name = sample_info_tab$Sample.Name,
Location = sample_info_tab$Glacier,
Lat_Long = sample_info_tab$lat_lon,
Elevation = sample_info_tab$elev,
Diameter1 = sample_info_tab$diameter1,
Diameter2 = sample_info_tab$diameter2,
Organic_matter = sample_info_tab$org_matter,
Water_content = sample_info_tab$water_content,
Variable1 = sample_info_tab$undefined,
Variable2 = sample_info_tab$undefined.2,
Variable3 = sample_info_tab$undefined.3,
row.names = sample_info_tab$Sample.Name,
stringsAsFactors = FALSE
))
taxonomy <- taxonomy %>%
mutate(taxonomy=str_replace_all(string=Taxon, pattern="D_\\d*\\__", replacement="")) %>%
mutate(taxonomy=str_replace_all(string=taxonomy, pattern=";$", replacement="")) %>%
separate(taxonomy, into=c("Kingdom", "Phylum", "Class", "Order", "Family", "Genus", "Species"), sep=";") %>%
select(-Taxon, -Confidence) %>%
column_to_rownames(var='Feature ID')
# A logical vector showing which entries are 'TRUE' for controls and 'FALSE' for genuine samples
decontam <- startsWith(sampledata$Sample_name, "NT")
# Run isContaminant (remember to transform the dataframe i.e. t())
contam <- isContaminant(t(count_table), neg=decontam)
# Look at the results
table(contam$contaminant) # how many ASVs were identified as contaminants? None. Why?
# Make a vector holding the contaminant IDs
contam_asvs <- row.names(contam[contam$contaminant == TRUE, ])
# What is the taxonomy of our contaminant ASVs?
taxonomy[taxonomy$`Feature ID` %in% contam_asvs] #Why don't I have any contaminants?!?
###COUNT TABLE
x <- rownames(count_table) %in% contam_asvs #which rows are contaminants?
count_table_clean <- count_table[!x,] #remove those rows
# and remove blank samples from count table
#what is the index of "TRUE" values in decontam?
true_index <- NULL
for (i in 1:length(decontam)){
if (decontam[[i]] == "TRUE"){
true_index <- c(true_index, i)
}
}
count_table_clean <- count_table_clean[,-c(true_index)]  #remove those samples
###TAXONOMY TABLE
z <- taxonomy$`Feature ID` %in% contam_asvs
taxonomy_clean <- taxonomy[!row.names(taxonomy) %in% z,]#remove contaminating ASVs
###FASTA FILE
#Remove contaminants from dna sequences file
fasta_clean <- fasta
fasta_clean[contam_asvs] <- NULL
###METADATA TABLE
y <- startsWith(sampledata$Sample_name, "NT")
true_index <- NULL
for (i in 1:length(y)){
if (y[[i]] == "TRUE"){
true_index <- c(true_index, i)
}
}
sampledata_clean <- sampledata[-c(true_index),]  #remove those samples
###PHYLOGENETIC TREE
# This is a phyloseq object so we can use a phyloseq command called prune_taxa
tree_clean <- prune_taxa(count_table_clean$`#OTU ID`, tree)
#Plot the rarefaction curves, color-coding by sample and tranform using t()
#Col= option could also be used to look at different sample types/locations?
pdf("rplot.pdf")
rarecurve(t(count_table_clean), step=100, cex=0.5, col=palette(rainbow(nrow(sampledata_clean))), lwd=2, ylab="ASVs", label=T)
# Add line to indicate the fewest # of sequences from any sample
abline(v=(min(rowSums(t(count_table_clean)))))
dev.off()
###COUNT TABLE
# Convert count table to phyloseq package
count_table_phyloseq <- otu_table(count_table_clean, taxa_are_rows = TRUE)
# Filter using prune_taxa
count_table_phyloseq <- prune_taxa(taxa_sums(count_table_phyloseq) > 1, count_table_phyloseq)
###TAXONOMY TABLE
taxonomy_clean_and_not_single <- taxonomy_clean[row.names(taxonomy_clean) %in% row.names(count_table_phyloseq),] #remove singletons
rownames(taxonomy_clean_and_not_single) <- rownames(count_table_phyloseq)
###PHYLOGENETIC TREE
# This is a phyloseq object so we can use a phyloseq command called prune_taxa
tree_clean_and_single <- prune_taxa(count_table_phyloseq$`#OTU ID`, tree)
###PHYLOGENETIC TREE
# This is a phyloseq object so we can use a phyloseq command called prune_taxa
tree_clean_and_single <- prune_taxa(count_table_phyloseq, tree_clean)
###PHYLOGENETIC TREE
# This is a phyloseq object so we can use a phyloseq command called prune_taxa
tree_clean_and_single <- prune_taxa(taxa_sums(count_table_phyloseq) > 1, tree_clean)
x <- taxa_sums(count_table_phyloseq) > 1
tree_clean
###COUNT TABLE
# Convert count table to phyloseq package
count_table_phyloseq <- otu_table(count_table_clean, taxa_are_rows = TRUE)
# Filter using prune_taxa
count_table_phyloseq_prune <- prune_taxa(taxa_sums(count_table_phyloseq) > 1, count_table_phyloseq)
###PHYLOGENETIC TREE
# This is a phyloseq object so we can use a phyloseq command called prune_taxa
tree_clean_and_single <- prune_taxa(taxa_sums(count_table_phyloseq) > 1, tree_clean)
###TAXONOMY TABLE
TAX = tax_table(taxonomy_clean)
class(count_table_clean)
class(taxonomy_clean)
###TAXONOMY TABLE
TAX = tax_table(as.matrix(taxonomy_clean))
###COUNT TABLE
# Convert count table to phyloseq package
count_table_phyloseq <- otu_table(as.matrix(count_table_clean), taxa_are_rows = TRUE)
TAX_prune <- prune_taxa(taxa_sums(count_table_phyloseq) > 1, TAX)
TAX_prune
head(TAX_prune)
nrow(TAX_prune)
###METADATA TABLE
META = sample_data(sampledata_clean)
META_prune <- prune_taxa(taxa_sums(count_table_phyloseq) > 1, META)
head(META)
head(count_table_phyloseq_prune)
ncol(count_table_phyloseq_prune)
nrow(META)
rm(list=ls())
graphics.off()
